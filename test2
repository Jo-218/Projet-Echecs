import tkinter as tk

# Caractères Unicode pour les pièces d'échecs
UNICODE_PIECES = {
    'R_white': '♖', 'N_white': '♘', 'B_white': '♗', 'Q_white': '♕', 'K_white': '♔', 'P_white': '♙',
    'R_black': '♜', 'N_black': '♞', 'B_black': '♝', 'Q_black': '♛', 'K_black': '♚', 'P_black': '♟'
}

# Mapping de la position initiale des pièces
INITIAL_BOARD = {
    'a1': 'R_white', 'b1': 'N_white', 'c1': 'B_white', 'd1': 'Q_white', 'e1': 'K_white', 'f1': 'B_white', 'g1': 'N_white', 'h1': 'R_white',
    'a2': 'P_white', 'b2': 'P_white', 'c2': 'P_white', 'd2': 'P_white', 'e2': 'P_white', 'f2': 'P_white', 'g2': 'P_white', 'h2': 'P_white',
    'a7': 'P_black', 'b7': 'P_black', 'c7': 'P_black', 'd7': 'P_black', 'e7': 'P_black', 'f7': 'P_black', 'g7': 'P_black', 'h7': 'P_black',
    'a8': 'R_black', 'b8': 'N_black', 'c8': 'B_black', 'd8': 'Q_black', 'e8': 'K_black', 'f8': 'B_black', 'g8': 'N_black', 'h8': 'R_black',
}


def file_rank_to_index(fr):
    """Convertit la notation d'échecs (a1, e4) en index de grille (col, lig)."""
    file = ord(fr[0]) - ord('a')
    rank = int(fr[1:]) - 1
    return file, 7 - rank


def index_to_file_rank(col, row):
    """Convertit les index de grille (col, lig) en notation d'échecs (a1, e4)."""
    file = chr(ord('a') + col)
    rank = 8 - row
    return f"{file}{rank}"


def get_piece_color(piece_str):
    if not piece_str:
        return None
    return 'white' if '_white' in piece_str else 'black'


class ChessGame:
    def __init__(self, root):
        self.root = root
        self.root.title("Mon Jeu d'Échecs")
        self.root.geometry("600x700")

        self.color_light = "#eeeed2"
        self.color_dark = "#769656"
        self.square_size = 60

        self.main_frame = tk.Frame(self.root)
        self.main_frame.pack(expand=True, fill="both")

        self.board = INITIAL_BOARD.copy()
        self.current_turn = 'white'
        self.selected_square = None

        self.show_menu()

    def show_menu(self):
        self.clear_frame()

        self.label_title = tk.Label(
            self.main_frame,
            text="Jeu d'Échecs",
            font=("Helvetica", 32, "bold"),
            pady=50
        )
        self.label_title.pack()

        self.btn_play = tk.Button(
            self.main_frame,
            text="Jouer",
            font=("Helvetica", 18),
            command=self.start_game,
            width=15,
            height=2,
            bg="#4CAF50",
            fg="white"
        )
        self.btn_play.pack(pady=20)

    def start_game(self):
        self.clear_frame()

        self.canvas = tk.Canvas(self.main_frame, width=480, height=480)
        self.canvas.pack(pady=12)
        self.canvas.bind("<Button-1>", self.on_click)

        self.status_label = tk.Label(self.main_frame, text=f"Tour de {self.current_turn}", font=("Helvetica", 14))
        self.status_label.pack(pady=4)

        self.draw_board_and_pieces()

        self.btn_back = tk.Button(self.main_frame, text="Retour au menu", command=self.show_menu)
        self.btn_back.pack(pady=8)

    def draw_board_and_pieces(self):
        self.canvas.delete("all")
        piece_font = ("Helvetica", 32)

        for row in range(8):
            for col in range(8):
                color = self.color_light if (row + col) % 2 == 0 else self.color_dark
                x1 = col * self.square_size
                y1 = row * self.square_size
                x2 = x1 + self.square_size
                y2 = y1 + self.square_size
                self.canvas.create_rectangle(x1, y1, x2, y2, fill=color, outline="")

                square_fr = index_to_file_rank(col, row)
                piece_str = self.board.get(square_fr)
                if piece_str:
                    unicode_char = UNICODE_PIECES.get(piece_str, "")
                    if unicode_char:
                        self.canvas.create_text(
                            x1 + self.square_size / 2,
                            y1 + self.square_size / 2,
                            text=unicode_char,
                            font=piece_font,
                            fill="black" if get_piece_color(piece_str) == 'black' else "white",
                            anchor="center"
                        )

        if self.selected_square:
            col, row = file_rank_to_index(self.selected_square)
            x1 = col * self.square_size
            y1 = row * self.square_size
            x2 = x1 + self.square_size
            y2 = y1 + self.square_size
            self.canvas.create_rectangle(x1, y1, x2, y2, outline="yellow", width=3)

    def on_click(self, event):
        col = event.x // self.square_size
        row = event.y // self.square_size
        if col < 0 or col >= 8 or row < 0 or row >= 8:
            return

        clicked_square = index_to_file_rank(col, row)
        clicked_piece = self.board.get(clicked_square)
        clicked_color = get_piece_color(clicked_piece)

        if self.selected_square is None:
            if clicked_piece and clicked_color == self.current_turn:
                self.selected_square = clicked_square
                self.draw_board_and_pieces()
            return

        if clicked_square == self.selected_square:
            self.selected_square = None
            self.draw_board_and_pieces()
            return

        if clicked_piece and clicked_color == self.current_turn:
            self.selected_square = clicked_square
            self.draw_board_and_pieces()
            return

        if self.is_valid_move(self.selected_square, clicked_square):
            self.board[clicked_square] = self.board[self.selected_square]
            del self.board[self.selected_square]
            self.selected_square = None
            self.current_turn = 'black' if self.current_turn == 'white' else 'white'
            self.status_label.config(text=f"Tour de {self.current_turn}")
        self.draw_board_and_pieces()

    def is_valid_move(self, start, end):
        if start == end or start not in self.board:
            return False

        piece_str = self.board[start]
        piece_type, piece_color = piece_str.split('_')
        destination_piece = self.board.get(end)
        destination_color = get_piece_color(destination_piece)

        if destination_color == piece_color:
            return False

        sc, sr = file_rank_to_index(start)
        ec, er = file_rank_to_index(end)
        dc = ec - sc
        dr = er - sr

        if piece_type == 'P':
            return self.is_valid_pawn_move(sc, sr, ec, er, piece_color, destination_piece)
        if piece_type == 'N':
            return self.is_valid_knight_move(dc, dr)
        if piece_type == 'K':
            return self.is_valid_king_move(dc, dr)
        if piece_type == 'B':
            return self.is_valid_bishop_move(sc, sr, ec, er)
        if piece_type == 'R':
            return self.is_valid_rook_move(sc, sr, ec, er)
        if piece_type == 'Q':
            return self.is_valid_queen_move(sc, sr, ec, er)

        return False

    def is_valid_pawn_move(self, sc, sr, ec, er, color, destination_piece):
        direction = -1 if color == 'white' else 1
        start_row = 6 if color == 'white' else 1
        dc = ec - sc
        dr = er - sr

        if dc == 0:
            if dr == direction and not destination_piece:
                return True
            if sr == start_row and dr == 2 * direction:
                intermediate_square = index_to_file_rank(sc, sr + direction)
                if not destination_piece and not self.board.get(intermediate_square):
                    return True
            return False

        if abs(dc) == 1 and dr == direction and destination_piece and get_piece_color(destination_piece) != color:
            return True

        return False

    def is_valid_knight_move(self, dc, dr):
        return (abs(dc), abs(dr)) in {(1, 2), (2, 1)}

    def is_valid_king_move(self, dc, dr):
        return max(abs(dc), abs(dr)) == 1

    def is_valid_bishop_move(self, sc, sr, ec, er):
        if abs(ec - sc) != abs(er - sr):
            return False
        return self.is_path_clear(sc, sr, ec, er)

    def is_valid_rook_move(self, sc, sr, ec, er):
        if sc != ec and sr != er:
            return False
        return self.is_path_clear(sc, sr, ec, er)

    def is_valid_queen_move(self, sc, sr, ec, er):
        if sc == ec or sr == er or abs(ec - sc) == abs(er - sr):
            return self.is_path_clear(sc, sr, ec, er)
        return False

    def is_path_clear(self, sc, sr, ec, er):
        step_c = 0 if ec == sc else (1 if ec > sc else -1)
        step_r = 0 if er == sr else (1 if er > sr else -1)
        c, r = sc + step_c, sr + step_r
        while (c, r) != (ec, er):
            if self.board.get(index_to_file_rank(c, r)):
                return False
            c += step_c
            r += step_r
        return True

    def clear_frame(self):
        for widget in self.main_frame.winfo_children():
            widget.destroy()


if __name__ == "__main__":
    root = tk.Tk()
    game = ChessGame(root)
    root.mainloop()

