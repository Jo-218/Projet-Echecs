import tkinter as tk
from tkinter import messagebox

# Caractères Unicode pour les pièces
PIECES = {
    'white': {'P': '♙', 'R': '♖', 'N': '♘', 'B': '♗', 'Q': '♕', 'K': '♔'},
    'black': {'P': '♟', 'R': '♜', 'N': '♞', 'B': '♝', 'Q': '♛', 'K': '♚'}
}

class ChessGame:
    def __init__(self, root):
        self.root = root
        self.root.title("Échecs Python - Master Edition")
        self.root.geometry("500x650")
        self.root.configure(bg="#1a1a1a") # Fond sombre global

        # Conteneur principal pour basculer entre menu et jeu
        self.main_container = tk.Frame(self.root, bg="#1a1a1a")
        self.main_container.pack(expand=True, fill="both")

        self.difficulty = "Normal"
        self.en_passant_target = None
        self.game_over = False
        
        # Lancer le menu au démarrage
        self.show_start_menu()

    def clear_container(self):
        """Nettoie tout le contenu de la fenêtre."""
        for widget in self.main_container.winfo_children():
            widget.destroy()

    def show_start_menu(self):
        """Affiche l'écran d'accueil sombre."""
        self.clear_container()

        # Titre
        tk.Label(
            self.main_container, 
            text="CHESS MASTER", 
            font=("Courier", 32, "bold"), 
            bg="#1a1a1a", 
            fg="#d4af37", # Couleur Or
            pady=50
        ).pack()

        # Bouton Jouer
        btn_style = {"font": ("Helvetica", 12, "bold"), "width": 20, "height": 2, "bd": 0, "cursor": "hand2"}
        
        tk.Button(
            self.main_container, 
            text="JOUER", 
            bg="#2ecc71", fg="white",
            command=self.init_game_ui,
            **btn_style
        ).pack(pady=10)

        # Bouton Difficulté
        self.diff_btn = tk.Button(
            self.main_container, 
            text=f"DIFFICULTÉ : {self.difficulty}", 
            bg="#34495e", fg="white",
            command=self.toggle_difficulty,
            **btn_style
        )
        self.diff_btn.pack(pady=10)

        # Pied de page
        tk.Label(
            self.main_container, 
            text="2026 - IA Chess Engine", 
            font=("Arial", 8), 
            bg="#1a1a1a", 
            fg="#555"
        ).pack(side="bottom", pady=20)

    def toggle_difficulty(self):
        """Change la difficulté (visuel uniquement ici)."""
        levels = ["Facile", "Normal", "Difficile", "Grand Maître"]
        current_idx = levels.index(self.difficulty)
        self.difficulty = levels[(current_idx + 1) % len(levels)]
        self.diff_btn.config(text=f"DIFFICULTÉ : {self.difficulty}")

    def init_game_ui(self):
        """Prépare l'interface du plateau de jeu."""
        self.clear_container()
        
        # Label du tour
        self.status_label = tk.Label(
            self.main_container, 
            text="AU TOUR DES BLANCS", 
            font=("Helvetica", 14, "bold"), 
            bg="#1a1a1a", fg="white", 
            pady=10
        )
        self.status_label.pack()

        # Plateau
        self.canvas = tk.Canvas(self.main_container, width=480, height=480, bg="#1a1a1a", highlightthickness=0)
        self.canvas.pack(pady=10)
        self.canvas.bind("<Button-1>", self.handle_click)

        # Bouton de retour au menu
        tk.Button(
            self.main_container, 
            text="Abandonner / Menu", 
            bg="#e74c3c", fg="white", 
            command=self.show_start_menu
        ).pack(pady=5)

        self.reset_game_logic()

    def reset_game_logic(self):
        """Initialise l'état des pièces."""
        self.board = {}
        self.current_turn = 'white'
        self.selected_square = None
        self.game_over = False
        
        for color in ['white', 'black']:
            row, p_row = (7, 6) if color == 'white' else (0, 1)
            order = ['R', 'N', 'B', 'Q', 'K', 'B', 'N', 'R']
            for col, p_type in enumerate(order):
                self.board[(col, row)] = (p_type, color)
                self.board[(col, p_row)] = ('P', color)
        
        self.draw_board()

    def update_status_ui(self):
        color_text = "BLANCS" if self.current_turn == 'white' else "NOIRS"
        self.status_label.config(text=f"AU TOUR DES {color_text}", fg="#ecf0f1")

    def draw_board(self):
        self.canvas.delete("all")
        in_check_sq = self.get_king_square(self.current_turn) if self.is_in_check(self.current_turn, self.board) else None

        for r in range(8):
            for c in range(8):
                x1, y1 = c * 60, r * 60
                color = "#ebecd0" if (r + c) % 2 == 0 else "#779556" # Couleurs classiques
                
                if self.selected_square == (c, r):
                    color = "#f6f669"
                elif (c, r) == in_check_sq:
                    color = "#e74c3c"
                
                self.canvas.create_rectangle(x1, y1, x1+60, y1+60, fill=color, outline="")
                piece = self.board.get((c, r))
                if piece:
                    self.canvas.create_text(x1+30, y1+30, text=PIECES[piece[1]][piece[0]], font=("Arial", 36))

    def handle_click(self, event):
        if self.game_over: return
        col, row = event.x // 60, event.y // 60
        target = (col, row)

        if self.selected_square:
            if self.is_legal_move(self.selected_square, target):
                self.execute_move(self.selected_square, target)
                self.current_turn = 'black' if self.current_turn == 'white' else 'white'
                self.selected_square = None
                self.draw_board()
                self.update_status_ui()
                self.root.update()
                self.check_end_game()
            else:
                piece = self.board.get(target)
                if piece and piece[1] == self.current_turn:
                    self.selected_square = target
                else:
                    self.selected_square = None
        else:
            piece = self.board.get(target)
            if piece and piece[1] == self.current_turn:
                self.selected_square = target
        self.draw_board()

    # --- LOGIQUE TECHNIQUE (Simplifiée pour la lecture) ---
    
    def is_legal_move(self, start, end):
        if not self.can_piece_reach(start, end, self.board): return False
        temp_board = self.board.copy()
        temp_board[end] = temp_board[start]
        del temp_board[start]
        return not self.is_in_check(self.board[start][1], temp_board)

    def can_piece_reach(self, start, end, board):
        if not (0 <= end[0] < 8 and 0 <= end[1] < 8): return False
        p_info = board.get(start)
        if not p_info: return False
        p_type, color = p_info
        dx, dy = end[0] - start[0], end[1] - start[1]
        adx, ady = abs(dx), abs(dy)
        target_p = board.get(end)

        if target_p and target_p[1] == color: return False
        if p_type == 'P':
            direction = -1 if color == 'white' else 1
            if dx == 0 and dy == direction and not target_p: return True
            if dx == 0 and dy == 2*direction and not target_p and start[1] == (6 if color == 'white' else 1):
                return not board.get((start[0], start[1]+direction))
            if adx == 1 and dy == direction and (target_p or end == self.en_passant_target): return True
        elif p_type == 'R': return (dx == 0 or dy == 0) and self.is_path_clear(start, end, board)
        elif p_type == 'N': return (adx, ady) in [(1, 2), (2, 1)]
        elif p_type == 'B': return adx == ady and self.is_path_clear(start, end, board)
        elif p_type == 'Q': return (dx == 0 or dy == 0 or adx == ady) and self.is_path_clear(start, end, board)
        elif p_type == 'K': return adx <= 1 and ady <= 1
        return False

    def is_path_clear(self, start, end, board):
        step_x = 0 if end[0] == start[0] else (1 if end[0] > start[0] else -1)
        step_y = 0 if end[1] == start[1] else (1 if end[1] > start[1] else -1)
        curr = (start[0] + step_x, start[1] + step_y)
        while curr != end:
            if curr in board: return False
            curr = (curr[0] + step_x, curr[1] + step_y)
        return True

    def is_in_check(self, color, board):
        king_pos = next((pos for pos, p in board.items() if p == ('K', color)), None)
        if not king_pos: return False
        opp = 'black' if color == 'white' else 'white'
        return any(self.can_piece_reach(pos, king_pos, board) for pos, p in board.items() if p[1] == opp)

    def get_king_square(self, color):
        return next((pos for pos, p in self.board.items() if p == ('K', color)), None)

    def execute_move(self, start, end):
        p_type, color = self.board[start]
        self.board[end] = self.board[start]
        del self.board[start]
        if p_type == 'P' and end[1] in [0, 7]: # Promotion auto Reine par défaut pour fluidité
            self.board[end] = ('Q', color)

    def check_end_game(self):
        has_legal_move = False
        for pos, piece in self.board.items():
            if piece[1] == self.current_turn:
                for r in range(8):
                    for c in range(8):
                        if self.is_legal_move(pos, (c, r)):
                            has_legal_move = True; break
                    if has_legal_move: break
            if has_legal_move: break
        
        if not has_legal_move:
            self.game_over = True
            winner = "NOIRS" if self.current_turn == "white" else "BLANCS"
            messagebox.showinfo("Fin de partie", f"Échec et Mat ! Victoire des {winner}.")

if __name__ == "__main__":
    root = tk.Tk()
    game = ChessGame(root)
    root.mainloop()
