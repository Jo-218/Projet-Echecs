# --- CLASSE BOARD [cite: 110] ---
class Board:
    def __init__(self):
        self.grid = {} # Utilisation d'un dictionnaire (Contrainte )
        self.reset_board()

    def reset_board(self):
        # Initialisation simplifiée pour l'exemple [cite: 116]
        for col in 'abcdefgh':
            self.grid[f"{col}2"] = Pawn(Position(col, 2), 0)
            self.grid[f"{col}7"] = Pawn(Position(col, 7), 1)
        # Ajout des Rois [cite: 76]
        self.grid["e1"] = King(Position("e", 1), 0)
        self.grid["e8"] = King(Position("e", 8), 1)

    def get_piece(self, pos_str):
        return self.grid.get(pos_str, None) # [cite: 115]

