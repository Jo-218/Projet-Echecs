import tkinter as tk
from tkinter import messagebox, simpledialog

PIECES = {
    'white': {'P': '♙', 'R': '♖', 'N': '♘', 'B': '♗', 'Q': '♕', 'K': '♔'},
    'black': {'P': '♟', 'R': '♜', 'N': '♞', 'B': '♝', 'Q': '♛', 'K': '♚'}
}

class ChessGame:
    def __init__(self, root):
        self.root = root
        self.root.title("Échecs Pro - Python")
        self.root.geometry("500x600")
        
        self.canvas = tk.Canvas(self.root, width=480, height=480)
        self.canvas.pack(pady=20)
        self.canvas.bind("<Button-1>", self.handle_click)

        self.en_passant_target = None  # Stocke la case possible pour une prise en passant
        self.reset_game()

    def reset_game(self):
        self.board = {}
        self.current_turn = 'white'
        self.selected_square = None
        
        for color in ['white', 'black']:
            row, p_row = (7, 6) if color == 'white' else (0, 1)
            order = ['R', 'N', 'B', 'Q', 'K', 'B', 'N', 'R']
            for col, p_type in enumerate(order):
                self.board[(col, row)] = (p_type, color)
                self.board[(col, p_row)] = ('P', color)
        
        self.draw_board()

    def draw_board(self):
        self.canvas.delete("all")
        in_check_sq = self.get_king_square(self.current_turn) if self.is_in_check(self.current_turn, self.board) else None

        for r in range(8):
            for c in range(8):
                x1, y1 = c * 60, r * 60
                # Couleurs de base
                color = "#eeeed2" if (r + c) % 2 == 0 else "#769656"
                
                # Surlignage (Sélection ou Échec)
                if self.selected_square == (c, r):
                    color = "#f7f769"
                elif (c, r) == in_check_sq:
                    color = "#ff7d7d" # Rouge si le roi est en échec
                
                self.canvas.create_rectangle(x1, y1, x1+60, y1+60, fill=color, outline="")
                piece = self.board.get((c, r))
                if piece:
                    self.canvas.create_text(x1+30, y1+30, text=PIECES[piece[1]][piece[0]], font=("Arial", 36))

    def handle_click(self, event):
        col, row = event.x // 60, event.y // 60
        target = (col, row)

        if self.selected_square:
            if self.is_legal_move(self.selected_square, target):
                self.execute_move(self.selected_square, target)
                self.current_turn = 'black' if self.current_turn == 'white' else 'white'
                self.selected_square = None
            else:
                piece = self.board.get(target)
                if piece and piece[1] == self.current_turn:
                    self.selected_square = target
                else:
                    self.selected_square = None
        else:
            piece = self.board.get(target)
            if piece and piece[1] == self.current_turn:
                self.selected_square = target
        
        self.draw_board()

    def is_legal_move(self, start, end):
        """Vérifie si le coup est possible ET s'il ne laisse pas le roi en échec (clouage)."""
        if not self.can_piece_reach(start, end, self.board):
            return False
        
        # Simulation pour vérifier l'échec (Gestion des clouages)
        temp_board = self.board.copy()
        temp_board[end] = temp_board[start]
        del temp_board[start]
        
        # Cas spécial En Passant : supprimer le pion capturé derrière
        if self.board[start][0] == 'P' and end == self.en_passant_target:
            cap_row = end[1] + (1 if self.board[start][1] == 'white' else -1)
            if (end[0], cap_row) in temp_board: del temp_board[(end[0], cap_row)]

        return not self.is_in_check(self.board[start][1], temp_board)

    def can_piece_reach(self, start, end, board):
        """Logique de mouvement pure de la pièce."""
        p_type, color = board[start]
        dx, dy = end[0] - start[0], end[1] - start[1]
        adx, ady = abs(dx), abs(dy)
        target_p = board.get(end)

        if target_p and target_p[1] == color: return False

        if p_type == 'P':
            dir = -1 if color == 'white' else 1
            # Avance
            if dx == 0 and dy == dir and not target_p: return True
            # Double avance
            if dx == 0 and dy == 2*dir and not target_p and start[1] == (6 if color == 'white' else 1):
                return not board.get((start[0], start[1]+dir))
            # Capture classique
            if adx == 1 and dy == dir and target_p: return True
            # EN PASSANT
            if adx == 1 and dy == dir and end == self.en_passant_target: return True
            return False

        if p_type == 'R': return (dx == 0 or dy == 0) and self.is_path_clear(start, end, board)
        if p_type == 'N': return (adx, ady) in [(1, 2), (2, 1)]
        if p_type == 'B': return adx == ady and self.is_path_clear(start, end, board)
        if p_type == 'Q': return (dx == 0 or dy == 0 or adx == ady) and self.is_path_clear(start, end, board)
        if p_type == 'K': return adx <= 1 and ady <= 1
        return False

    def is_path_clear(self, start, end, board):
        step_x = 0 if end[0] == start[0] else (1 if end[0] > start[0] else -1)
        step_y = 0 if end[1] == start[1] else (1 if end[1] > start[1] else -1)
        curr = (start[0] + step_x, start[1] + step_y)
        while curr != end:
            if curr in board: return False
            curr = (curr[0] + step_x, curr[1] + step_y)
        return True

    def is_in_check(self, color, board):
        """Vérifie si le roi de la couleur donnée est attaqué."""
        king_pos = None
        for pos, piece in board.items():
            if piece == ('K', color):
                king_pos = pos
                break
        if not king_pos: return False
        
        opp_color = 'black' if color == 'white' else 'white'
        for pos, piece in board.items():
            if piece[1] == opp_color:
                if self.can_piece_reach(pos, king_pos, board):
                    return True
        return False

    def get_king_square(self, color):
        for pos, piece in self.board.items():
            if piece == ('K', color): return pos

    def execute_move(self, start, end):
        p_type, color = self.board[start]
        
        # Gestion En Passant (Suppression du pion capturé)
        if p_type == 'P' and end == self.en_passant_target:
            cap_row = end[1] + (1 if color == 'white' else -1)
            del self.board[(end[0], cap_row)]

        # Mise à jour du prochain En Passant possible
        self.en_passant_target = (start[0], start[1] + (-1 if color == 'white' else 1)) if p_type == 'P' and abs(end[1]-start[1]) == 2 else None

        # Déplacement
        self.board[end] = self.board[start]
        del self.board[start]

        # PROMOTION
        if p_type == 'P' and end[1] in [0, 7]:
            self.board[end] = ('Q', color) # Promotion automatique en Reine pour simplifier

if __name__ == "__main__":
    root = tk.Tk()
    game = ChessGame(root)
    root.mainloop()
