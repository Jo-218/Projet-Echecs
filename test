# --- CLASSE PRINCIPALE CHESS & GUI [cite: 128] ---
class Chess(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Projet Échecs 2025/2026")
        self.board = Board() # [cite: 131]
        self.players = [Player("Joueur 1", 0), Player("Joueur 2", 1)] # [cite: 132]
        self.current_player = self.players[0] # [cite: 133]
        self.selected_pos = None
        
        self.setup_ui()

    def setup_ui(self):
        self.canvas = tk.Canvas(self, width=400, height=400)
        self.canvas.pack(side=tk.LEFT)
        self.canvas.bind("<Button-1>", self.on_click)
        
        btn_frame = tk.Frame(self)
        btn_frame.pack(side=tk.RIGHT, fill=tk.Y)
        
        tk.Button(btn_frame, text="Sauvegarder", command=self.save_game).pack(pady=5) # [cite: 10]
        tk.Button(btn_frame, text="Charger", command=self.load_game).pack(pady=5) # [cite: 10]
        
        self.label_status = tk.Label(self, text=f"Tour : {self.current_player.name}")
        self.label_status.pack()
        
        self.display_board()

    def display_board(self): # [cite: 142]
        self.canvas.delete("all")
        colors = ["#eeeed2", "#769656"]
        for r in range(8):
            for c in range(8):
                color = colors[(r + c) % 2]
                self.canvas.create_rectangle(c*50, r*50, (c+1)*50, (r+1)*50, fill=color)
                
                pos_str = f"{chr(97+c)}{8-r}"
                piece = self.board.get_piece(pos_str)
                if piece:
                    p_color = "white" if piece.color == 0 else "black"
                    self.canvas.create_text(c*50+25, r*50+25, text=str(piece), fill=p_color, font=("Arial", 20))

    def on_click(self, event):
        col = chr(97 + (event.x // 50))
        row = 8 - (event.y // 50)
        pos_click = f"{col}{row}"
        
        if not self.selected_pos:
            if self.board.get_piece(pos_click):
                self.selected_pos = pos_click
        else:
            self.update_board(f"{self.selected_pos} {pos_click}") # [cite: 146]
            self.selected_pos = None
            self.switch_player() # [cite: 147]
            self.display_board()

    def update_board(self, move): # [cite: 146]
        start, end = move.split()
        if start in self.board.grid:
            piece = self.board.grid.pop(start)
            piece.position = Position(end[0], end[1])
            self.board.grid[end] = piece

    def switch_player(self): # [cite: 147]
        self.current_player = self.players[1] if self.current_player == self.players[0] else self.players[0]
        self.label_status.config(text=f"Tour : {self.current_player.name}")

    def save_game(self): # [cite: 10]
        data = {pos: str(p) for pos, p in self.board.grid.items()}
        with open("save_chess.json", "w") as f:
            json.dump(data, f)
        messagebox.showinfo("Sauvegarde", "Partie enregistrée !")

    def load_game(self): # [cite: 10]
        try:
            with open("save_chess.json", "r") as f:
                data = json.load(f)
                # Logique de reconstruction à approfondir
                messagebox.showinfo("Chargement", "Partie restaurée (vue simplifiée) !")
        except FileNotFoundError:
            messagebox.showerror("Erreur", "Aucun fichier de sauvegarde trouvé.")

if __name__ == "__main__":
    app = Chess()
    app.mainloop()
