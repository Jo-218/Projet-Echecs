import tkinter as tk
from tkinter import messagebox

# Caractères Unicode pour les pièces d'échecs
UNICODE_PIECES = {
    'R_white': '♖', 'N_white': '♘', 'B_white': '♗', 'Q_white': '♕', 'K_white': '♔', 'P_white': '♙',
    'R_black': '♜', 'N_black': '♞', 'B_black': '♝', 'Q_black': '♛', 'K_black': '♚', 'P_black': '♟'
}

# Mapping de la position initiale des pièces
INITIAL_BOARD = {
    'a1': 'R_white', 'b1': 'N_white', 'c1': 'B_white', 'd1': 'Q_white', 'e1': 'K_white', 'f1': 'B_white', 'g1': 'N_white', 'h1': 'R_white',
    'a2': 'P_white', 'b2': 'P_white', 'c2': 'P_white', 'd2': 'P_white', 'e2': 'P_white', 'f2': 'P_white', 'g2': 'P_white', 'h2': 'P_white',
    'a7': 'P_black', 'b7': 'P_black', 'c7': 'P_black', 'd7': 'P_black', 'e7': 'P_black', 'f7': 'P_black', 'g7': 'P_black', 'h7': 'P_black',
    'a8': 'R_black', 'b8': 'N_black', 'c8': 'B_black', 'd8': 'Q_black', 'e8': 'K_black', 'f8': 'B_black', 'g8': 'N_black', 'h8': 'R_black',
}

def file_rank_to_index(fr):
    """Convertit la notation d'échecs (a1, e4) en index de grille (col, lig)."""
    file = ord(fr[0]) - ord('a')
    rank = int(fr[1:]) - 1
    return (file, 7 - rank) # l'index 0,0 est en haut à gauche (8e rangée)

def index_to_file_rank(col, row):
    """Convertit les index de grille (col, lig) en notation d'échecs (a1, e4)."""
    file = chr(ord('a') + col)
    rank = 7 - row + 1
    return file + str(rank)

def get_piece_color(piece_str):
    if not piece_str:
        return None
    return 'white' if '_white' in piece_str else 'black'

class ChessGame:
    def __init__(self, root):
        self.root = root
        self.root.title("Mon Jeu d'Échecs")
        self.root.geometry("600x700")
        
        # Couleurs du plateau
        self.color_light = "#eeeed2"
        self.color_dark = "#769656"
        
        # Conteneur principal
        self.main_frame = tk.Frame(self.root)
        self.main_frame.pack(expand=True, fill="both")

        # Initialisation de l'état du jeu
        self.board = INITIAL_BOARD.copy()
        self.current_turn = 'white'
        self.selected_square = None # La case sur laquelle l'utilisateur a cliqué pour sélectionner une pièce
        
        self.show_menu()

    def show_menu(self):
        """Affiche l'écran d'accueil avec le bouton Jouer."""
        self.clear_frame()
        
        self.label_title = tk.Label(
            self.main_frame, 
            text="Jeu d'Échecs", 
            font=("Helvetica", 32, "bold"),
            pady=50
        )
        self.label_title.pack()

        self.btn_play = tk.Button(
            self.main_frame, 
            text="Jouer", 
            font=("Helvetica", 18),
            command=self.start_game,
            width=15,
            height=2,
            bg="#4CAF50",
            fg="white"
        )
        self.btn_play.pack(pady=20)

    def start_game(self):
        """Initialise le plateau de jeu."""
        self.clear_frame()
        
        # Création du canvas pour le plateau (8x8 cases)
        self.canvas = tk.Canvas(self.main_frame, width=480, height=480)
        self.canvas.pack(pady=40)
        self.canvas.bind("<Button-1>", self.on_click) # Gérer les clics de souris
        
        self.draw_board_and_pieces()
        
        # Bouton retour
        self.btn_back = tk.Button(self.main_frame, text="Retour au menu", command=self.show_menu)
        self.btn_back.pack()

    def draw_board_and_pieces(self):
        """Dessine les 64 cases du plateau et les pièces dessus."""
        self.canvas.delete("all") # Nettoyer le canvas avant de redessiner
        square_size = 60
        piece_font = ("Helvetica", 32)
        
        for row in range(8):
            for col in range(8):
                # Dessiner la case
                color = self.color_light if (row + col) % 2 == 0 else self.color_dark
                x1 = col * square_size
                y1 = row * square_size
                x2 = x1 + square_size
                y2 = y1 + square_size
                self.canvas.create_rectangle(x1, y1, x2, y2, fill=color, outline="")

                # Dessiner la pièce si elle est présente
                square_fr = index_to_file_rank(col, row)
                piece_str = self.board.get(square_fr)
                if piece_str:
                    unicode_char = UNICODE_PIECES.get(piece_str, "")
                    if unicode_char:
                        self.canvas.create_text(
                            x1 + square_size // 2, 
                            y1 + square_size // 2, 
                            text=unicode_char, 
                            font=piece_font, 
                            anchor="center"
                        )
                        
        # Mettre en évidence la case sélectionnée (si il y en a une)
        if self.selected_square:
            col, row = file_rank_to_index(self.selected_square)
            x1 = col * square_size
            y1 = row * square_size
            x2 = x1 + square_size
            y2 = y1 + square_size
            self.canvas.create_rectangle(x1, y1, x2, y2, outline="yellow", width=3)
            # Mettre en évidence les coups possibles (plus tard)

    def on_click(self, event):
        """Gère le clic de souris sur le plateau."""
        square_size = 60
        col = event.x // square_size
        row = event.y // square_size
        clicked_square = index_to_file_rank(col, row)
        piece_on_clicked_square = self.board.get(clicked_square)
        piece_on_clicked_square_color = get_piece_color(piece_on_clicked_square)
        
        # Première selection
        if self.selected_square is None: 
            if piece_on_clicked_square and piece_on_clicked_square_color == self.current_turn:
                self.selected_square = clicked_square
                self.draw_board_and_pieces() # Mettre en évidence la case sélectionnée
            else:
                # Clic sur une case vide ou sur une pièce de l'adversaire (invalide)
                pass 
        
        # Deuxième clic : déplacement ou nouvelle sélection
        else:
            if clicked_square == self.selected_square:
                # Clic sur la même case -> désélectionner
                self.selected_square = None
            elif piece_on_clicked_square and piece_on_clicked_square_color == self.current_turn:
                # Clic sur une autre de ses pièces -> sélectionner cette pièce à la place
                self.selected_square = clicked_square
            else:
                # Clic sur une case vide ou sur une pièce de l'adversaire -> essayer de déplacer
                start_square = self.selected_square
                end_square = clicked_square
                if self.is_valid_move(start_square, end_square):
                    # Faire le mouvement
                    self.board[end_square] = self.board[start_square]
                    del self.board[start_square]
                    # Changer de tour
                    self.current_turn = 'black' if self.current_turn == 'white' else 'white'
                    self.selected_square = None # Désélectionner après le mouvement
                else:
                    # Mouvement invalide -> rien faire (l'utilisateur peut essayer un autre coup ou désélectionner)
                    pass
            self.draw_board_and_pieces() # Redessiner le plateau pour mettre à jour l'état

    def is_valid_move(self, start, end):
        """Vérifie si le mouvement d'une pièce est valide d'après les règles de base."""
        # Pour une implémentation complète, il faudrait un code très complexe pour chaque pièce, 
        # incluant les captures diagonales des pions, la prise en passant, le roque, etc.
        # Ici, nous allons faire une version très simplifiée : 
        # permettre tout mouvement vers une case vide ou occupée par l'adversaire, 
        # sauf pour les pions qui ne peuvent pas reculer et avancent de 1 case.
        
        piece_str = self.board[start]
        start_col, start_row = file_rank_to_index(start)
        end_col, end_row = file_rank_to_index(end)
        end_piece_str = self.board.get(end)
        
        # Les pions ne peuvent pas se déplacer à travers une autre pièce, 
        # et leurs mouvements sont très spécifiques
        if '_P_' in piece_str or '_white' in piece_str and piece_str.startswith('P'):
             if get_piece_color(piece_str) == 'white':
                # Uniquement vers le haut (rank augmente)
                return start_col == end_col and end_row < start_row and abs(end_row - start_row) == 1 and not end_piece_str
             else: # noir
                # Uniquement vers le bas (rank diminue)
                return start_col == end_col and end_row > start_row and abs(end_row - start_row) == 1 and not end_piece_str
        
        # Pour toutes les autres pièces, pour l'instant, on n'autorise aucun mouvement 
        # sauf si on clique sur une case de l'adversaire (ce qui est une capture)
        # return True if not end_piece_str or get_piece_color(end_piece_str) != self.current_turn else False
        return False # Pour l'instant on désactive tout mouvement sauf les pions pour montrer que la logique de sélection/désélection fonctionne

    def clear_frame(self):
        """Nettoie le contenu actuel de la fenêtre."""
        for widget in self.main_frame.winfo_children():
            widget.destroy()

# Lancement de l'application
if __name__ == "__main__":
    root = tk.Tk()
    game = ChessGame(root)
    root.mainloop()
