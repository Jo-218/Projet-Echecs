# --- CLASSE POSITION [cite: 74, 75] ---
class Position:
    def __init__(self, column, row):
        self.column = str(column)  # Caractère 'a'-'h' [cite: 78]
        self.row = int(row)        # Entier 1-8 [cite: 78]

    def to_coords(self):
        """Convertit 'a1' en indices (row, col) pour la matrice."""
        col_idx = ord(self.column) - ord('a')
        row_idx = 8 - self.row
        return row_idx, col_idx

    def __str__(self):
        return f"{self.column}{self.row}" # [cite: 81]

