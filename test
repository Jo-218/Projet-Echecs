import tkinter as tk
from tkinter import messagebox

# Caractères Unicode pour les pièces
PIECES = {
    'white': {'P': '♙', 'R': '♖', 'N': '♘', 'B': '♗', 'Q': '♕', 'K': '♔'},
    'black': {'P': '♟', 'R': '♜', 'N': '♞', 'B': '♝', 'Q': '♛', 'K': '♚'}
}

class ChessGame:
    def __init__(self, root):
        self.root = root
        self.root.title("Échecs Python")
        self.root.geometry("500x600")
        
        self.canvas = tk.Canvas(self.root, width=480, height=480)
        self.canvas.pack(pady=20)
        self.canvas.bind("<Button-1>", self.handle_click)

        self.reset_game()

    def reset_game(self):
        """Initialise l'état du plateau et des variables."""
        self.board = {} # Dictionnaire {(col, row): (type, color)}
        self.current_turn = 'white'
        self.selected_square = None
        
        # Placement des pièces
        for color in ['white', 'black']:
            row = 7 if color == 'white' else 0
            pawn_row = 6 if color == 'white' else 1
            
            # Pièces lourdes
            order = ['R', 'N', 'B', 'Q', 'K', 'B', 'N', 'R']
            for col, p_type in enumerate(order):
                self.board[(col, row)] = (p_type, color)
                self.board[(col, pawn_row)] = ('P', color)
        
        self.draw_board()

    def draw_board(self):
        self.canvas.delete("all")
        for r in range(8):
            for c in range(8):
                x1, y1 = c * 60, r * 60
                color = "#eeeed2" if (r + c) % 2 == 0 else "#769656"
                
                # Mise en surbrillance si sélectionné
                if self.selected_square == (c, r):
                    color = "#f7f769"
                
                self.canvas.create_rectangle(x1, y1, x1+60, y1+60, fill=color, outline="")
                
                # Affichage de la pièce
                piece = self.board.get((c, r))
                if piece:
                    p_type, p_color = piece
                    self.canvas.create_text(x1+30, y1+30, text=PIECES[p_color][p_type], font=("Arial", 36))

    def handle_click(self, event):
        col, row = event.x // 60, event.y // 60
        target = (col, row)

        if self.selected_square:
            if self.is_valid_move(self.selected_square, target):
                # Exécuter le mouvement
                self.board[target] = self.board[self.selected_square]
                del self.board[self.selected_square]
                
                # Changement de tour
                self.current_turn = 'black' if self.current_turn == 'white' else 'white'
                self.selected_square = None
            else:
                # Changer de sélection si on clique sur une autre de ses propres pièces
                piece = self.board.get(target)
                if piece and piece[1] == self.current_turn:
                    self.selected_square = target
                else:
                    self.selected_square = None
        else:
            piece = self.board.get(target)
            if piece and piece[1] == self.current_turn:
                self.selected_square = target
        
        self.draw_board()

    def is_valid_move(self, start, end):
        if start == end: return False
        
        piece_type, color = self.board[start]
        target_piece = self.board.get(end)
        
        # On ne peut pas manger sa propre pièce
        if target_piece and target_piece[1] == color:
            return False

        dx = end[0] - start[0]
        dy = end[1] - start[1]
        adx, ady = abs(dx), abs(dy)

        # LOGIQUE PAR PIÈCE
        if piece_type == 'P': # PION
            direction = -1 if color == 'white' else 1
            # Avancer de 1
            if dx == 0 and dy == direction and not target_piece:
                return True
            # Premier mouvement (de 2)
            if dx == 0 and dy == 2*direction and not target_piece:
                start_row = 6 if color == 'white' else 1
                if start[1] == start_row and not self.board.get((start[0], start[1]+direction)):
                    return True
            # Capture diagonale
            if adx == 1 and dy == direction and target_piece:
                return True
            return False

        if piece_type == 'R': # TOUR
            if dx == 0 or dy == 0:
                return self.is_path_clear(start, end)
            return False

        if piece_type == 'N': # CAVALIER
            return (adx, ady) in [(1, 2), (2, 1)]

        if piece_type == 'B': # FOU
            if adx == ady:
                return self.is_path_clear(start, end)
            return False

        if piece_type == 'Q': # REINE
            if dx == 0 or dy == 0 or adx == ady:
                return self.is_path_clear(start, end)
            return False

        if piece_type == 'K': # ROI
            return adx <= 1 and ady <= 1

        return False

    def is_path_clear(self, start, end):
        """Vérifie s'il y a des obstacles entre deux cases (hors Cavalier)."""
        step_x = 0 if end[0] == start[0] else (1 if end[0] > start[0] else -1)
        step_y = 0 if end[1] == start[1] else (1 if end[1] > start[1] else -1)
        
        curr_x, curr_y = start[0] + step_x, start[1] + step_y
        while (curr_x, curr_y) != end:
            if (curr_x, curr_y) in self.board:
                return False
            curr_x += step_x
            curr_y += step_y
        return True

if __name__ == "__main__":
    root = tk.Tk()
    game = ChessGame(root)
    root.mainloop()
