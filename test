import tkinter as tk
from tkinter import messagebox

def saluer():
    messagebox.showinfo("Message", "Bonjour ! Bienvenue dans votre application Tkinter.")

# 1. Création de l'instance principale (la fenêtre)
root = tk.Tk()

# 2. Configuration de la fenêtre
root.title("Mon Application")
root.geometry("400x300")  # Largeur x Hauteur en pixels

# 3. Ajout de composants (widgets)
label = tk.Label(root, text="Ceci est une fenêtre Tkinter", font=("Arial", 14))
label.pack(pady=20)  # "pack" place le widget et "pady" ajoute de l'espace vertical

bouton_salut = tk.Button(root, text="Cliquez-moi", command=saluer)
bouton_salut.pack(pady=10)

bouton_quitter = tk.Button(root, text="Quitter", command=root.quit, fg="red")
bouton_quitter.pack(pady=10)

# 4. Lancement de la boucle principale (maintient la fenêtre ouverte)
root.mainloop()
